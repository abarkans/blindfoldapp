NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
RESEND_API_KEY=your_resend_api_key
# Verified-domain sender. Falls back to resend.dev sandbox if unset
# (sandbox only delivers to the Resend account owner — set this in prod).
RESEND_FROM_ADDRESS=BlindfoldDate <info@blindfolddate.com>
CRON_SECRET=your_random_secret_string
DELETION_HOLD_PEPPER=your_long_random_secret_for_email_hash
PLACE_PHOTO_HMAC_SECRET=your_long_random_secret_for_place_photo_urls
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Cloudflare Turnstile — bot protection on auth surface (signup, login,
# password reset, resend). Site key is public; secret is set in the
# Supabase Dashboard (Authentication > Settings > Captcha protection).
# Dev test keys (always pass): site=1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key
# Cloudflare R2 — photo storage (Memory Challenge feature)
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=blindfolddate-photos
# PostHog analytics (EU region, cookieless mode)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Sentry error monitoring (EU datacenter — ingest.de.sentry.io)
NEXT_PUBLIC_SENTRY_DSN=https://key@oXXX.ingest.de.sentry.io/project
# Sentry source map upload — get from Settings → Auth Tokens (scope: project:releases)
# Set in Vercel env (sensitive) to enable readable stack traces in production.
SENTRY_AUTH_TOKEN=your_sentry_auth_token
# Contact form — email address where submissions are delivered.
# Set in Vercel env (sensitive).
CONTACT_TO_EMAIL=you@example.com
